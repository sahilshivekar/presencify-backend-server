{
  "info": {
    "name": "Student Auth API",
    "_postman_id": "student-auth-api-collection",
    "description": "Postman collection for Student Auth API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login Student",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "login"]
        }
      }
    },
    {
      "name": "Send Verification Code to Email",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/send-verification-code",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "send-verification-code"]
        }
      }
    },
    {
      "name": "Refresh Tokens",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/access-token",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "access-token"]
        }
      }
    },
    {
      "name": "Update Student Password",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/update-password",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "update-password"]
        }
      }
    },
    {
      "name": "Verify Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/verify-code",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "verify-code"]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/students/logout",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "auth", "students", "logout"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ]
}